{
  "expo": {
    "name": "Board Academy",
    "slug": "board-academy",
    "version": "2.116621.3",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1694d1"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.base69a73ce716a9ce7953fb465f.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1694d1",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.board.academy",
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "static"
    },
    "scheme": "boardacademy",
    "extra": {
      "eas": {
        "projectId": "cd2ff306-be96-4a30-aee4-49f0a44d4e11"
      }
    },
    "plugins": [
      ["expo-router", { "origin": "https://academy.board.com" }],
      "expo-secure-store"
    ]
  }
}
