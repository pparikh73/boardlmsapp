{
  "expo": {
    "name": "Board Academy",
    "slug": "board-academy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1694d1"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.board.academy"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1694d1",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.board.academy",
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "static"
    },
    "scheme": "boardacademy",
    "extra": {
      "eas": {
        "projectId": "aa2b69a6-b53c-4d1d-9cd3-eb8272d468a0"
      }
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      "expo-secure-store"
    ]
  }
}
